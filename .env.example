# ── Required ──────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional — Search Engine Configuration ────────────────────────────────────
# Options: ddg (default), google, bing, serpapi, custom
SEARCH_ENGINE=ddg

# Google Custom Search (only if SEARCH_ENGINE=google)
GOOGLE_API_KEY=
GOOGLE_CX=

# Bing Search API (only if SEARCH_ENGINE=bing)
BING_API_KEY=

# SerpAPI (only if SEARCH_ENGINE=serpapi)
SERPAPI_KEY=

# Custom endpoint (only if SEARCH_ENGINE=custom)
CUSTOM_SEARCH_URL=
